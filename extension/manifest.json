{
  "manifest_version": 3,
  "name": "ComicTrans Manga Overlay",
  "description": "Translate manga images on raw pages with your local ComicTrans backend.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "ComicTrans"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["activeTab", "sidePanel", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
