{
  "name": "comictrans-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "electron": "npx electron .",
    "desktop": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && npx electron .\"",
    "electron:install": "npm install --save-dev electron@^31.1.0",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "devDependencies": {}
}
